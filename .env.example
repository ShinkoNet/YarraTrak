# PTV Notify - Server Environment Variables
# Copy this file to .env and fill in your values.

# PTV API credentials (required)
# Register at https://www.ptv.vic.gov.au/footer/data-and-reporting/datasets/ptv-timetable-api/
PTV_DEV_ID=your_ptv_dev_id
PTV_API_KEY=your_ptv_api_key

# Optional hardening for public deployments
# Comma-separated list of trusted browser origins for CORS, e.g. https://ptv.example.com
ALLOWED_ORIGINS=
# Per-IP request budgets, counted over a rolling 60 second window
HTTP_QUERY_RATE_LIMIT=12
HTTP_FAVOURITE_RATE_LIMIT=60
WS_QUERY_RATE_LIMIT=12
# Concurrent websocket connections allowed from a single client IP
MAX_WS_CONNECTIONS_PER_IP=3
# Maximum number of favourite buttons accepted from a client
MAX_FAVOURITE_BUTTONS=10
# Maximum text length accepted for an AI query
MAX_QUERY_LENGTH=300

# Favourite refresh tuning
FAVOURITE_CACHE_TTL_SECONDS=45
FAVOURITE_FETCH_CONCURRENCY=20

# Operational metrics logging
METRICS_LOG_INTERVAL_SECONDS=60
METRICS_HISTORY_INTERVAL_SECONDS=60
METRICS_HISTORY_MAX_POINTS=360

# Host routing
PUBLIC_BASE_HOST=ptv.netcavy.net
INTERNAL_DASHBOARD_HOST=ptv.internal.website
PUBLIC_APPSTORE_URL=https://apps.repebble.com/

# Shared upstream HTTP client pool
HTTP_CLIENT_TIMEOUT_SECONDS=10
HTTP_CLIENT_MAX_CONNECTIONS=40
HTTP_CLIENT_MAX_KEEPALIVE_CONNECTIONS=20
